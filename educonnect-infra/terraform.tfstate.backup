            "id": "2174060905",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::239143558455:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/0668ECDADD70B807130D12155DF24DA3\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.us-east-1.amazonaws.com/id/0668ECDADD70B807130D12155DF24DA3:sub\": \"system:serviceaccount:kube-system:aws-load-balancer-controller\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::239143558455:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/0668ECDADD70B807130D12155DF24DA3\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.us-east-1.amazonaws.com/id/0668ECDADD70B807130D12155DF24DA3:sub\":\"system:serviceaccount:kube-system:aws-load-balancer-controller\"}}}]}",
            "override_json": null,
            "override_policy_documents": null,
            "policy_id": null,
            "source_json": null,
            "source_policy_documents": null,
            "statement": [
              {
                "actions": [
                  "sts:AssumeRoleWithWebIdentity"
                ],
                "condition": [
                  {
                    "test": "StringEquals",
                    "values": [
                      "system:serviceaccount:kube-system:aws-load-balancer-controller"
                    ],
                    "variable": "oidc.eks.us-east-1.amazonaws.com/id/0668ECDADD70B807130D12155DF24DA3:sub"
                  }
                ],
                "effect": "Allow",
                "not_actions": [],
